  "metrics": [
    {
      "metric_id": "HDI_S",
      "name": "Human Dependency Index - Structural",
      "category": "dependency",
      "description": "Measures how much the system depends on human-specific structural knowledge or manual intervention.",
      "unit": "percent",
      "desired_direction": "lower_is_better",
      "formula_status": "foundation_defined_formula_encoding_pending",
      "inputs": [
        "structural constraints",
        "manual steps",
        "single-point human approvals",
        "fallback coverage"
      ],
      "thresholds": [
        {
          "min": 0,
          "max": 39,
          "label": "healthy",
          "risk_level": "low",
          "default_action": "continue"
        },
        {
          "min": 40,
          "max": 79,
          "label": "watch",
          "risk_level": "medium",
          "default_action": "review"
        },
        {
          "min": 80,
          "max": 100,
          "label": "rebuild",
          "risk_level": "critical",
          "default_action": "stop_and_rebuild"
        }
      ]
    },
    {
      "metric_id": "HDI_D",
      "name": "Human Dependency Index - Decision",
      "category": "dependency",
      "description": "Measures how much key decisions rely on specific humans instead of governed structure.",
      "unit": "percent",
      "desired_direction": "lower_is_better",
      "formula_status": "foundation_defined_formula_encoding_pending",
      "inputs": [
        "decision rights",
        "authority concentration",
        "override concentration",
        "appeal availability"
