      "thresholds": [
        {
          "min": 0,
          "max": 39,
          "label": "healthy",
          "risk_level": "low",
          "default_action": "continue"
        },
        {
          "min": 40,
          "max": 79,
          "label": "watch",
          "risk_level": "medium",
          "default_action": "review"
        },
        {
          "min": 80,
          "max": 100,
          "label": "rebuild",
          "risk_level": "critical",
          "default_action": "stop_and_rebuild"
        }
      ]
    },
    {
