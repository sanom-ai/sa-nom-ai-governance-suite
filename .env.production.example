SANOM_ENV=production
SANOM_API_TOKEN=replace-with-secure-owner-token
SANOM_SERVER_HOST=0.0.0.0
SANOM_SERVER_PORT=8080
SANOM_SERVER_PUBLIC_BASE_URL=https://sanom.example.internal
SANOM_STRICT_STARTUP_VALIDATION=true
SANOM_ACCESS_PROFILES_REQUIRE_HASHES=true
SANOM_SESSION_TTL_MINUTES=720
SANOM_SESSION_IDLE_TIMEOUT_MINUTES=60
SANOM_TRUSTED_REGISTRY_KEY=replace-with-secure-registry-key
SANOM_TRUSTED_REGISTRY_KEY_ID=SANOM_PROD_REGISTRY
SANOM_TRUSTED_REGISTRY_SIGNED_BY=EXEC_OWNER
SANOM_TRUSTED_REGISTRY_REQUIRE_SIGNATURE=true
SANOM_RETENTION_AUDIT_DAYS=2555
SANOM_RETENTION_OVERRIDE_DAYS=2555
SANOM_RETENTION_LOCK_DAYS=30
SANOM_RETENTION_CONSISTENCY_DAYS=365
SANOM_RETENTION_SESSION_DAYS=90
SANOM_RETENTION_ROLE_PRIVATE_STUDIO_DAYS=2555
SANOM_RETENTION_ARCHIVE_DIR=runtime_archive
SANOM_PERSISTENCE_BACKEND=file
SANOM_POSTGRES_DSN=postgresql://sanom:change-me@postgres:5432/sanom
SANOM_POSTGRES_SCHEMA=public
SANOM_POSTGRES_NATIVE_ENABLED=false
SANOM_POSTGRES_CONNECT_TIMEOUT_SECONDS=5
SANOM_COORDINATION_BACKEND=file
SANOM_REDIS_URL=redis://default:change-me@redis:6379/0
SANOM_REDIS_NATIVE_ENABLED=false
SANOM_REDIS_QUEUE_NAMESPACE=sanom
SANOM_REDIS_CONNECT_TIMEOUT_SECONDS=5
SANOM_OUTBOUND_HTTP_INTEGRATIONS_ENABLED=false
SANOM_INTEGRATION_DELIVERY_TIMEOUT_SECONDS=5
SANOM_INTEGRATION_DEFAULT_MAX_ATTEMPTS=3
SANOM_INTEGRATION_RETRY_BACKOFF_MS=250

# Optional enterprise-target services for future scale-up
SANOM_POSTGRES_DB=sanom
SANOM_POSTGRES_USER=sanom
SANOM_POSTGRES_PASSWORD=change-me
